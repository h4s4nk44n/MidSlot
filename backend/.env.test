# Test-only env. Loaded by jest.setup.ts before any test file runs.
# DO NOT use these values in production.

NODE_ENV=test
JWT_SECRET=test_jwt_secret_at_least_32_characters_long_for_assertion_xx
JWT_ACCESS_TTL=1h
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=test_refresh_secret_at_least_32_characters_long_xxxxxxxx
JWT_REFRESH_TTL=7d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/midslot_test?schema=public
DISABLE_RATE_LIMIT=true
COOKIE_SECURE=false
ALLOWED_ORIGINS=http://localhost:3001
