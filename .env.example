# ─────────────────────────────────────────────────────────────
# Root env — consumed by docker-compose.yml via ${VAR} expansion.
# Copy to .env and edit:  cp .env.example .env
# This file is NOT used when running services outside Docker —
# see backend/.env.example and frontend/.env.example for that.
# ─────────────────────────────────────────────────────────────

# ── Postgres ───────────────────────────────────────────────
# Credentials for the bundled `postgres` service. Change for any
# non-throwaway deploy.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=midslot
# Uncomment in compose to expose Postgres on the host (and pick a free port):
# POSTGRES_HOST_PORT=5433

# ── Backend ────────────────────────────────────────────────
# DATABASE_URL is built from the POSTGRES_* vars above; override only if
# the backend should talk to an EXTERNAL database instead of the bundled one.
# DATABASE_URL=postgresql://user:pass@host:5432/db?schema=public
NODE_ENV=production
BACKEND_HOST_PORT=3000
ALLOWED_ORIGINS=http://localhost:3001

# JWT — REQUIRED. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=CHANGE_ME_generate_with_node_-e_console.log(require('crypto').randomBytes(48).toString('base64url'))
JWT_ACCESS_TTL=1h
# Optional: separate refresh-token secret. Defaults to JWT_SECRET if unset.
REFRESH_TOKEN_SECRET=
JWT_REFRESH_TTL=7d

# IANA timezone used to evaluate "today" for the same-day appointment-start
# check. Set this when the server runs in a different timezone than the clinic
# (e.g. server in UTC, clinic in Istanbul). Defaults to the runtime timezone.
CLINIC_TIMEZONE=Europe/Istanbul

# ── Frontend ───────────────────────────────────────────────
# Baked into the JS bundle at BUILD TIME. Must be the URL the user's browser
# will use to reach the backend — i.e. the host-side port, not "backend:3000".
NEXT_PUBLIC_API_URL=http://localhost:3000/api
FRONTEND_HOST_PORT=3001
