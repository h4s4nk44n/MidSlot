# Server
PORT=3000

# Database — update with your actual PostgreSQL credentials
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/midslot?schema=public"

# JWT Settings
JWT_SECRET=midslot-super-secret-key-2026
JWT_EXPIRES_IN=1h

# Refresh Token Settings
REFRESH_TOKEN_SECRET=midslot-refresh-secret-key-2026
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS Configuration — Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173